{
    "version": 2,
    "builds": [
      {
        "src": "next.config.mjs",
        "use": "@vercel/next",
        "config": {
          "maxLambdaSize": "15mb",
          "nodeVersion": "18.x",
          "buildCommand": "npm run build"
        }
      }
    ],
    "build": {
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096 --stack-size=65500",
        "NEXT_TELEMETRY_DISABLED": "1"
      }
    },
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/$1",
        "continue": true,
        "headers": {
          "x-matched-path": "/$1"
        }
      }
    ],
    "functions": {
      "api/*": {
        "memory": 3008,
        "maxDuration": 60
      },
      "pages/*": {
        "memory": 3008,
        "maxDuration": 60
      }
    }
  }