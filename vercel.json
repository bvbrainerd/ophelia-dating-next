{
    "version": 2,
    "builds": [
      {
        "src": "next.config.mjs",
        "use": "@vercel/next",
        "config": {
          "maxLambdaSize": "15mb",
          "nodeVersion": "18.x"
        }
      }
    ],
    "build": {
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096 --stack-size=65500"
      }
    },
    "functions": {
      "api/*": {
        "memory": 3008,
        "maxDuration": 60
      }
    }
  }